SECRET_KEY=replace-with-a-long-random-string
ADMIN_PASSWORD=replace-with-a-strong-password

# URL de connexion a la base de donnees (optionnelle).
# - Si vide : l'application utilise la base SQLite locale
#   (instance/mydatabase.db). Pratique pour le developpement.
# - Si renseignee : doit pointer vers une base PostgreSQL.
#   Exemple local : postgresql://postgres:motdepasse@localhost:5432/tir300
# - En production sur Render : la variable DATABASE_URL est injectee
#   automatiquement par la base PostgreSQL Render attachee au service web.
#   Render utilise historiquement le prefixe "postgres://" : l'application
#   le normalise en "postgresql://".
# DATABASE_URL=

# =============================================================
# Cloudflare R2 (stockage objet S3-compatible)
# =============================================================
# Necessaire pour servir les flyers, photos de galerie et PDFs de
# resultats. Sans ces variables, les uploads admin ne fonctionneront
# pas et les images existantes ne s'afficheront pas.
#
# Ou trouver ces valeurs ?
#   - R2_ACCOUNT_ID : Cloudflare dashboard > R2 > "Account ID"
#   - R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY : R2 > Manage R2 API Tokens
#       > Create API token (permissions: Object Read & Write)
#   - R2_BUCKET : nom du bucket cree (ex: tir300-uploads)
#   - R2_PUBLIC_URL : R2 > <bucket> > Settings > Public Development URL
#       OU domaine personnalise configure (sans slash final)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
