SECRET_KEY=replace-with-a-long-random-string
ADMIN_PASSWORD=replace-with-a-strong-password

# URL de connexion a la base de donnees (optionnelle).
# - Si vide : l'application utilise la base SQLite locale
#   (instance/mydatabase.db). Pratique pour le developpement.
# - Si renseignee : doit pointer vers une base PostgreSQL.
#   Exemple local : postgresql://postgres:motdepasse@localhost:5432/tir300
# - En production sur Render : la variable DATABASE_URL est injectee
#   automatiquement par la base PostgreSQL Render attachee au service web.
#   Render utilise historiquement le prefixe "postgres://" : l'application
#   le normalise en "postgresql://".
# DATABASE_URL=
